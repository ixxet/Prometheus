          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  $__timeGroupAlias(observed_at, '15m'),\n  result || ' ' || direction AS metric,\n  COUNT(*)::double precision AS value\nFROM athena.edge_observations\nWHERE $__timeFilter(observed_at)\n  AND facility_id IN (${facility:sqlstring})\n  AND zone_id IN (${zone:sqlstring})\n  AND node_id IN (${node:sqlstring})\nGROUP BY 1, 2\nORDER BY 1, 2;",
          "refId": "A"
        }
      ],
      "title": "Tap Volume",
      "type": "timeseries"
