          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT state AS metric, COUNT(*)::double precision AS value\nFROM athena.edge_sessions\nWHERE facility_id IN (${facility:sqlstring})\n  AND zone_id IN (${zone:sqlstring})\n  AND (entry_node_id IN (${node:sqlstring}) OR exit_node_id IN (${node:sqlstring}))\n  AND COALESCE(entry_at, exit_at, created_at) BETWEEN to_timestamp($__unixEpochFrom()) AND to_timestamp($__unixEpochTo())\nGROUP BY state\nORDER BY state;",
          "refId": "A"
        }
      ],
      "title": "Session Count By State",
      "type": "bargauge"
